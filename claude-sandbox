#!/usr/bin/env bash
# claude-sandbox — run Claude Code in a Docker container sandboxed to CWD
# Usage: claude-sandbox [--rebuild] [claude args...]
set -euo pipefail

IMAGE_NAME="claude-code-sandbox"
IMAGE_TAG="latest"
FULL_IMAGE="${IMAGE_NAME}:${IMAGE_TAG}"

# ── helpers ──────────────────────────────────────────────────────────────────

build_image() {
    echo "[claude-sandbox] Building Docker image (this takes ~1 min the first time)..."
    docker build --pull -t "${FULL_IMAGE}" - <<'DOCKERFILE'
FROM node:lts-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates git bash python3 python3-pip \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# Install Playwright CLI and Chromium with all system deps
RUN npm install -g @playwright/cli@latest && \
    npx playwright install --with-deps chromium

# Install Claude Code using the official native installer
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    cp /root/.local/bin/claude /usr/local/bin/claude

RUN mkdir -p /workspace && chmod 777 /workspace

WORKDIR /workspace

ENTRYPOINT ["claude"]
DOCKERFILE
    echo "[claude-sandbox] Image built successfully."
}

# ── argument parsing ─────────────────────────────────────────────────────────

REBUILD=false
PASS_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --rebuild|-r)
            REBUILD=true
            ;;
        *)
            PASS_ARGS+=("$arg")
            ;;
    esac
done

# ── ensure image exists ──────────────────────────────────────────────────────

if $REBUILD || ! docker image inspect "${FULL_IMAGE}" &>/dev/null; then
    build_image
fi

# ── credentials ──────────────────────────────────────────────────────────────

# Merge the claudeAiOauth token from the macOS Keychain into a temp credentials
# file so the container can authenticate without Keychain access.
CREDS_FILE=$(mktemp -t claude-sandbox-credentials)
KEYCHAIN_FILE=$(mktemp -t claude-sandbox-keychain)
trap 'rm -f "$CREDS_FILE" "$KEYCHAIN_FILE"' EXIT

security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null > "$KEYCHAIN_FILE" || echo '{}' > "$KEYCHAIN_FILE"

python3 - "$KEYCHAIN_FILE" "$HOME/.claude/.credentials.json" "$CREDS_FILE" <<'PYEOF'
import json, sys
keychain  = json.load(open(sys.argv[1])) if open(sys.argv[1]).read().strip() != '{}' else {}
try:
    existing = json.load(open(sys.argv[2]))
except Exception:
    existing = {}
merged = {**existing, **{k: v for k, v in keychain.items() if k == 'claudeAiOauth'}}
json.dump(merged, open(sys.argv[3], 'w'))
PYEOF

# ── launch ───────────────────────────────────────────────────────────────────

exec docker run \
    --rm \
    --interactive \
    --tty \
    --user "$(id -u):$(id -g)" \
    --env HOME="$HOME" \
    --publish 3118:3118 \
    --publish 10000:10000 \
    --publish 4321-4330:4321-4330 \
    --volume "$(pwd):/workspace" \
    --volume "$HOME/.claude:$HOME/.claude" \
    --volume "$HOME/.claude.json:$HOME/.claude.json" \
    --volume "${CREDS_FILE}:$HOME/.claude/.credentials.json" \
    --workdir /workspace \
    ${ANTHROPIC_BASE_URL:+--env ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL}"} \
    "${FULL_IMAGE}" \
    --dangerously-skip-permissions \
    "${PASS_ARGS[@]+"${PASS_ARGS[@]}"}"
