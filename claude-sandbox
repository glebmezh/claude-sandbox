#!/usr/bin/env bash
# claude-sandbox — run Claude Code in a Docker container sandboxed to CWD
# Usage: claude-sandbox [--rebuild] [claude args...]
set -euo pipefail

IMAGE_NAME="claude-code-sandbox"
IMAGE_TAG="latest"
FULL_IMAGE="${IMAGE_NAME}:${IMAGE_TAG}"

# ── helpers ──────────────────────────────────────────────────────────────────

build_image() {
    echo "[claude-sandbox] Building Docker image (this takes ~1 min the first time)..."
    docker build --pull -t "${FULL_IMAGE}" - <<'DOCKERFILE'
FROM node:lts-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates git bash python3 python3-pip \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# Install Playwright CLI and Chromium with all system deps
RUN npm install -g @playwright/cli@latest && \
    npx playwright install --with-deps chromium

# Install Claude Code using the official native installer
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    cp /root/.local/bin/claude /usr/local/bin/claude

# Pre-create home directory parents so the runtime user (non-root) can write there.
# /Users for macOS hosts, /home for Linux hosts.
RUN mkdir -p /Users /home /workspace && chmod 777 /Users /home /workspace

# Entrypoint: make ~/.claude.json writable (container-local copy) so the
# host file is never modified, while ~/.claude/ stays a live host mount.
RUN cat > /entrypoint.sh << 'EOF'
#!/bin/bash
# ~/.claude is mounted at /host-claude-dir (not under $HOME) so Docker
# never auto-creates $HOME as root. We create it ourselves as the runtime
# user, then symlink .claude into place and copy .claude.json locally.
mkdir -p "$HOME/.local/bin"
ln -sf /host-claude-dir "$HOME/.claude"
if [ -f /tmp/host-claude.json ]; then
    cp /tmp/host-claude.json "$HOME/.claude.json"
fi
exec claude "$@"
EOF
RUN chmod +x /entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
DOCKERFILE
    echo "[claude-sandbox] Image built successfully."
}

# ── argument parsing ─────────────────────────────────────────────────────────

REBUILD=false
SHELL_MODE=false
PASS_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --rebuild|-r)
            REBUILD=true
            ;;
        --shell|-s)
            SHELL_MODE=true
            ;;
        *)
            PASS_ARGS+=("$arg")
            ;;
    esac
done

# ── ensure image exists ──────────────────────────────────────────────────────

if $REBUILD || ! docker image inspect "${FULL_IMAGE}" &>/dev/null; then
    build_image
fi

# ── port allocation ──────────────────────────────────────────────────────────

free_port() {
    local port=$1
    while lsof -i ":${port}" -sTCP:LISTEN -t >/dev/null 2>&1; do
        ((port++))
    done
    echo "$port"
}

free_range() {
    # Find a block of 'count' consecutive free ports starting from 'start'
    local start=$1 count=$2
    while true; do
        local all_free=true
        for ((i=0; i<count; i++)); do
            if lsof -i ":$((start+i))" -sTCP:LISTEN -t >/dev/null 2>&1; then
                start=$((start+i+1)); all_free=false; break
            fi
        done
        $all_free && break
    done
    echo "$start"
}

PORT_SLACK=$(free_port 3118)
PORT_LOGIN=$(free_port 10000)
DEV_START=$(free_range 4321 10)
DEV_END=$((DEV_START + 9))

[[ "$PORT_SLACK"  != "3118"  ]] && echo "[claude-sandbox] Slack OAuth port:  localhost:${PORT_SLACK} → container:3118"
[[ "$PORT_LOGIN"  != "10000" ]] && echo "[claude-sandbox] Login callback port: localhost:${PORT_LOGIN} → container:10000"
[[ "$DEV_START"   != "4321"  ]] && echo "[claude-sandbox] Dev server ports:   localhost:${DEV_START}-${DEV_END} → container:4321-4330"

# ── credentials & config ─────────────────────────────────────────────────────

# Temp dir for all ephemeral files; cleaned up on exit.
SANDBOX_DIR=$(mktemp -d -t claude-sandbox)
trap 'rm -rf "$SANDBOX_DIR"' EXIT

# Create project .claude dir if it doesn't exist
mkdir -p "$(pwd)/.claude"

# Share conversation history with local Claude: compute the same project key
# Claude uses (absolute path with / → -) and ensure the dir exists in both places.
PROJECT_KEY=$(pwd | sed 's|/|-|g')
GLOBAL_HISTORY_DIR="$HOME/.claude/projects/$PROJECT_KEY"
LOCAL_HISTORY_DIR="$(pwd)/.claude/projects/$PROJECT_KEY"
mkdir -p "$GLOBAL_HISTORY_DIR" "$LOCAL_HISTORY_DIR"

# Build merged credentials: claudeAiOauth (Keychain) + mcpOAuth (project file if any)
KEYCHAIN_FILE="$SANDBOX_DIR/keychain.json"
CREDS_FILE="$SANDBOX_DIR/credentials.json"
security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null > "$KEYCHAIN_FILE" || echo '{}' > "$KEYCHAIN_FILE"

python3 - "$KEYCHAIN_FILE" "$(pwd)/.claude/.credentials.json" "$CREDS_FILE" <<'PYEOF'
import json, sys
keychain = json.load(open(sys.argv[1]))
try:
    existing = json.load(open(sys.argv[2]))
except Exception:
    existing = {}
merged = {**existing, **{k: v for k, v in keychain.items() if k == 'claudeAiOauth'}}
json.dump(merged, open(sys.argv[3], 'w'))
PYEOF

# Synthesize ~/.claude.json with HTTP mcpServers only (stdio servers reference
# host paths that don't exist in the container — silently drop them).
CLAUDE_JSON_FILE="$SANDBOX_DIR/.claude.json"
python3 - "$HOME/.claude.json" "$CLAUDE_JSON_FILE" <<'PYEOF'
import json, sys
try:
    src = json.load(open(sys.argv[1]))
except Exception:
    src = {}
http_servers = {k: v for k, v in src.get('mcpServers', {}).items()
                if v.get('type') == 'http'}
out = {k: v for k, v in src.items() if k not in ('mcpServers', 'projects', 'githubRepoPaths')}
out['mcpServers'] = http_servers
json.dump(out, open(sys.argv[2], 'w'))
PYEOF

# ── launch ───────────────────────────────────────────────────────────────────

echo "[claude-sandbox] Dev server → http://localhost:${DEV_START} on your Mac"

exec docker run \
    --rm \
    --interactive \
    --tty \
    --user "$(id -u):$(id -g)" \
    --env HOME="$HOME" \
    --env HOST=0.0.0.0 \
    --env SANDBOX_DEV_PORT="${DEV_START}" \
    --publish "127.0.0.1:${PORT_SLACK}:3118" \
    --publish "127.0.0.1:${PORT_LOGIN}:10000" \
    --publish "127.0.0.1:${DEV_START}-${DEV_END}:4321-4330" \
    --volume "$(pwd):/workspace" \
    --volume "$(pwd)/.claude:/host-claude-dir" \
    --volume "$HOME/.claude/plugins:/host-claude-dir/plugins:ro" \
    --volume "$HOME/.claude/skills:/host-claude-dir/skills:ro" \
    --volume "$GLOBAL_HISTORY_DIR:/host-claude-dir/projects/$PROJECT_KEY" \
    --volume "$CREDS_FILE:/host-claude-dir/.credentials.json" \
    --volume "$CLAUDE_JSON_FILE:/tmp/host-claude.json:ro" \
    --workdir /workspace \
    ${ANTHROPIC_BASE_URL:+--env ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL}"} \
    $($SHELL_MODE && echo "--entrypoint bash") \
    "${FULL_IMAGE}" \
    $($SHELL_MODE || echo "--dangerously-skip-permissions") \
    "${PASS_ARGS[@]+"${PASS_ARGS[@]}"}"
